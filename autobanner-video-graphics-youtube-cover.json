        "gradient_overlay": {
          "label": "Gradient Overlay",
          "type": "toggle",
          "default_visible": true,
          "asset": "Gradient Youtube Cover.png",
          "layer_position": "between_background_and_kv",
          "flip_for_right_aligned_layout": true
        },
        "brand_logo": {
          "label": "Brand Logo",
          "type": "toggle_with_scale",
          "default_visible": true,
          "asset": "Uploaded Brand Logo",
          "scaling_allowed": true,
          "scale_anchor": "top_right",
          "placeholder": "red rectangle with LOGO text"
        },
        "program_title": {
          "label": "Program Title",
          "type": "toggle_with_text_override",
          "default_visible": true,
          "default_text": "Program Name",
          "override_text": ""
        },
        "quotation_name": {
          "label": "Quotation mark + Name",
          "type": "toggle_with_text_override",
          "default_visible": true,
          "quotation_mark": {
            "default_visible": true,
            "type": "image",
            "left_aligned_asset": "Quotation Right.png",
            "right_aligned_asset": "Quotation Left.png",
            "note": "Assets are mapped by visual quote direction: left-aligned text uses the opening quote image; right-aligned text uses the closing quote image."
          },
          "name": {
            "default_text": "某某某",
            "override_text": ""
          }
        },
        "zaobao_logo": {
          "label": "Zaobao Logo",
          "type": "fixed",
